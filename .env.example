# Copy to .env and edit values:
#   cp .env.example .env

# --- REQUIRED ---
EULA=TRUE

# --- CurseForge AUTO download (required for modpack auto-install) ---
# Get API key at https://console.curseforge.com/
# If your key contains '$', keep it wrapped in single quotes in .env, example:
# CF_API_KEY='$11$22$33aaaaaaaaaaaaaaaaaaaaaaaaaa'
CF_API_KEY='$2a$10$qQaEXv1w7Vzo.hL802W8LuO2sRUbDcCoQ0O5BuoPKHaaS0Sa37xTa'

# Modpack page or a pinned file URL:
# Page: https://www.curseforge.com/minecraft/modpacks/dawn-craft
# Latest (pinned): https://www.curseforge.com/minecraft/modpacks/dawn-craft/files/7243862
CF_PAGE_URL=https://www.curseforge.com/minecraft/modpacks/prominence-2-hasturian-era/files/7856383

# --- Server identity ---
SERVER_NAME=Prominence 
MOTD=\\u00A76Prominence\\u00A7r on Docker

# --- Gameplay ---
DIFFICULTY=normal
MAX_PLAYERS=4
ONLINE_MODE=false
VIEW_DISTANCE=16
SIMULATION_DISTANCE=16

# --- Access control ---
OPS=
WHITELIST=
ENFORCE_WHITELIST=false

# --- Memory / JVM ---
# VPS 16 GB RAM: typical safe start for DawnCraft is 10G-12G Xmx.
# Keep headroom for OS and disk cache.
INIT_MEMORY=4G
MAX_MEMORY=12G

# Aikar flags are a reasonable safe default; can help GC behavior.
USE_AIKAR_FLAGS=true

# Extra JVM flags you want to add.
# Note: Java 17 is used. Do NOT add flags that are removed in Java 17.
# Example for some modpacks: "-Dfml.readTimeout=180 -Dfml.queryResult=confirm"
JVM_OPTS=-Dfml.readTimeout=180 -Dfml.queryResult=confirm

# --- Timezone ---
TZ=UTC
