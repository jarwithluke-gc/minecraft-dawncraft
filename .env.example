# Copy to .env and edit values:
#   cp .env.example .env

# --- REQUIRED ---
EULA=TRUE

# DawnCraft commonly uses Forge 1.18.2 40.2.1
FORGE_VERSION=40.2.1

# --- Server identity ---
SERVER_NAME=DawnCraft 
MOTD=\\u00A76DawnCraft\\u00A7r on Docker

# --- Gameplay ---
DIFFICULTY=normal
MAX_PLAYERS=4
ONLINE_MODE=false
VIEW_DISTANCE=16
SIMULATION_DISTANCE=16

# --- Access control ---
OPS=
WHITELIST=
ENFORCE_WHITELIST=false

# --- Memory / JVM ---
# VPS 16 GB RAM: typical safe start for DawnCraft is 10G-12G Xmx.
# Keep headroom for OS and disk cache.
INIT_MEMORY=4G
MAX_MEMORY=12G

# Aikar flags are a reasonable safe default; can help GC behavior.
USE_AIKAR_FLAGS=true

# Extra JVM flags you want to add.
# Note: Java 17 is used. Do NOT add flags that are removed in Java 17.
# Example for some modpacks: "-Dfml.readTimeout=180 -Dfml.queryResult=confirm"
JVM_OPTS=-Dfml.readTimeout=180 -Dfml.queryResult=confirm

# --- Timezone ---
TZ=UTC
